# A Casa do Gi — variáveis de ambiente
# Copie este ficheiro para ".env" (dev local) OU defina estas variáveis no painel do Dokploy (produção).
# O ".env" real NÃO deve ser versionado (está no .gitignore).

# --- Base de dados (obrigatório) ---
DB_HOST=alojamentogi-mysql-8g3t8r
DB_NAME=casadogi
DB_USER=casadogi_user
DB_PASS=            # <-- definir a palavra-passe da BD aqui (segredo). ROTACIONAR a atual.
DB_PORT=3306

